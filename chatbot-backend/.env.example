# ── iX Chatbot Backend — environment variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── Required ─────────────────────────────────────────────────────────────────
# Siemens LLM API key — generate at my.siemens.com → My Keys → Create (scope: llm)
# Base URL: https://api.siemens.com/llm/v1
LLM_API_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────
# Port the backend listens on (default: 5000)
PORT=5000

# Comma-separated list of allowed CORS origins.
# Add your Docusaurus dev server and production URL.
# Example: http://localhost:3000,https://ix.siemens.io
CORS_ORIGINS=http://localhost:3000

# Set to "true" ONLY behind a corporate proxy that intercepts TLS.
# Never enable in production \u2014 this bypasses certificate validation.
ALLOW_INSECURE_SSL=false
